# ========================================
# Supabase Konfiguration
# ========================================
# Deine Supabase-Projekt-URL (z.B. https://xyzabcdef.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://DEIN_PROJEKT.supabase.co

# Supabase "anon" public key (sicher für Browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein_anon_key_hier

# Supabase service_role key (NUR server-seitig verwenden, NIEMALS im Browser!)
SUPABASE_SERVICE_ROLE_KEY=dein_service_role_key_hier

# ========================================
# App-Konfiguration
# ========================================
# Produktions-URL deiner App
NEXT_PUBLIC_SITE_URL=https://buendnisost.de

# ========================================
# E-Mail Konfiguration (optional, Supabase nutzt eigenen E-Mail-Server)
# ========================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=passwort
